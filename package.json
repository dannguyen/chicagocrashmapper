{
	"name": "chicagocrashmapper",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"devo": "vite dev --open",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"test": "vitest --run",
		"test:e2e:local": "PLAYWRIGHT_PROFILE=local playwright test --project=local",
		"test:e2e:api": "PLAYWRIGHT_PROFILE=api playwright test --project=api",
		"test:e2e": "npm run test:e2e:local && npm run test:e2e:api",
		"test:unit": "npm run test:unit -- --run",
		"test:all": "npm run test && npm run test:e2e"
	},
	"devDependencies": {
		"@playwright/test": "^1.50.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.48.6",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^24.10.1",
		"autoprefixer": "^10.4.19",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.0.9",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"maplibre-gl": "^5.20.0"
	}
}
